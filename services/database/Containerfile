FROM mongo:7.0

# Install additional tools
RUN apt-get update && apt-get install -y \
    curl \
    jq \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Create directories for initialization scripts
RUN mkdir -p /docker-entrypoint-initdb.d

# Copy initialization scripts
COPY ./init-scripts/ /docker-entrypoint-initdb.d/

# Copy MongoDB configuration
COPY ./mongod.conf /etc/mongod.conf

# Create data directory and set permissions
RUN mkdir -p /data/db && chown -R mongodb:mongodb /data/db

# Expose MongoDB port
EXPOSE 27017

# Set environment variables
ENV MONGO_INITDB_ROOT_USERNAME=admin
ENV MONGO_INITDB_ROOT_PASSWORD=projectmanager123
ENV MONGO_INITDB_DATABASE=project_manager

# Add healthcheck
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD mongo --eval "db.adminCommand('ping')" || exit 1

# Use custom entrypoint to ensure proper initialization
COPY ./docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

ENTRYPOINT ["docker-entrypoint.sh"]
CMD ["mongod", "--config", "/etc/mongod.conf"] 